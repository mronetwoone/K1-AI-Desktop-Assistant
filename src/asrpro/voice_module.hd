#include "asr.h"
extern "C"{ void * __dso_handle = 0 ;}
#include "setup.h"
#include "HardwareSerial.h"
#include "myLib/asr_event.h"

uint32_t snid;
void UART0_RX();
void ASR_CODE();
void app();

// ==================== 全局开关 ====================
// false：关闭坐姿检测播报，不响应 K1 发来的坐姿 AA 01~07 55
// true ：打开坐姿检测播报，正常响应 K1 坐姿指令
volatile bool posture_detect_enable = false;

// ==================== 学习计时器 ====================
// false：当前没有学习计时
// true ：正在学习计时
volatile bool study_timer_running = false;
uint32_t study_start_ms = 0;


// ==================== 协议定义 ====================
// K1 -> ASRPRO：
//   AA 01~07 55 [0D 0A]                 坐姿播报
//   AA 20 温度整数 湿度整数 55 [0D 0A]  温湿度播报
//   AA 21 55 [0D 0A]                    温湿度读取失败
// ASRPRO -> K1：
//   AB 20 55                            请求 K1 读取 face 板温湿度
static const uint8_t CMD_ENV_REPORT = 0x20;
static const uint8_t CMD_ENV_FAIL   = 0x21;

