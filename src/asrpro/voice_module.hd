// ==================== 2. 扩展语音话术轮播 ====================
void play_good_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10501);
  else if (idx == 1) play_audio(10506);
  else play_audio(10507);
  idx = (idx + 1) % 3;
}

void play_slouch_mild_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10502);
  else if (idx == 1) play_audio(10508);
  else play_audio(10509);
  idx = (idx + 1) % 3;
}

void play_shoulder_mild_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10503);
  else if (idx == 1) play_audio(10513);
  else play_audio(10514);
  idx = (idx + 1) % 3;
}

void play_slouch_severe_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10510);
  else if (idx == 1) play_audio(10511);
  else play_audio(10512);
  idx = (idx + 1) % 3;
}

void play_shoulder_severe_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10515);
  else if (idx == 1) play_audio(10516);
  else play_audio(10517);
  idx = (idx + 1) % 3;
}

void play_both_bad_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10518);
  else if (idx == 1) play_audio(10519);
  else play_audio(10520);
  idx = (idx + 1) % 3;
}

void play_person_lost_variant() {
  static uint8_t idx = 0;
  if (idx == 0) play_audio(10521);
  else play_audio(10522);
  idx = (idx + 1) % 2;
}

void play_number_0_99(uint8_t n) {
  if (n > 99) n = 99;
  play_audio(10700 + n);
}

void play_env_report(uint8_t temp, uint8_t hum) {
  if (temp > 99) temp = 99;
  if (hum > 99) hum = 99;

  play_audio(10600);      // 当前环境状态如下，温度
  delay(180);
  play_number_0_99(temp); // 数字
  delay(180);
  play_audio(10601);      // 摄氏度，湿度
  delay(180);
  play_number_0_99(hum);  // 数字
  delay(180);
  play_audio(10602);      // 百分之
}

void play_env_fail() {
  play_audio(10603);
}

uint32_t get_study_elapsed_seconds() {
  if (!study_timer_running) return 0;

  uint32_t now_ms = millis();
  // uint32_t 自然溢出相减仍可得到正确差值。
  uint32_t elapsed_ms = now_ms - study_start_ms;
  return elapsed_ms / 1000;
}

void play_duration_seconds(uint32_t total_seconds) {
  uint32_t hours = total_seconds / 3600;
  uint32_t minutes = (total_seconds % 3600) / 60;
  uint32_t seconds = total_seconds % 60;

  if (hours > 0) {
    if (hours > 99) hours = 99;
    play_number_0_99((uint8_t)hours);
    delay(180);
    play_audio(10616);      // 小时
    delay(180);

    if (minutes > 0) {
      play_number_0_99((uint8_t)minutes);
      delay(180);
      play_audio(10613);    // 分钟
      delay(180);
    }

    if (seconds > 0) {
      play_number_0_99((uint8_t)seconds);
      delay(180);
      play_audio(10614);    // 秒
    }
    return;
  }

  if (minutes > 0) {
    if (minutes > 99) minutes = 99;
    play_number_0_99((uint8_t)minutes);
    delay(180);
    play_audio(10613);      // 分钟
    delay(180);

    if (seconds > 0) {
      play_number_0_99((uint8_t)seconds);
      delay(180);
      play_audio(10614);    // 秒
    }
    return;
  }

  // 小于 1 分钟时，直接播报秒数。
  play_number_0_99((uint8_t)seconds);
  delay(180);
  play_audio(10614);        // 秒
}

void start_study_timer() {
  if (study_timer_running) {
    play_audio(10617);      // 学习计时已经在进行中
    delay(200);
    play_audio(10611);      // 您已经学习了
    delay(180);
    play_duration_seconds(get_study_elapsed_seconds());
    return;
  }

  study_timer_running = true;
  study_start_ms = millis();
  play_audio(10610);        // 已开始学习
}

void report_study_time() {
  if (!study_timer_running) {
    play_audio(10615);      // 当前还没有开始学习
    return;
  }

  play_audio(10611);        // 您已经学习了
  delay(180);
  play_duration_seconds(get_study_elapsed_seconds());
}

void stop_study_timer() {
  if (!study_timer_running) {
    play_audio(10615);      // 当前还没有开始学习
    return;
  }

  uint32_t total_seconds = get_study_elapsed_seconds();

  // 先停止并复位，避免播报过程中继续累计。
  study_timer_running = false;
  study_start_ms = 0;

  play_audio(10612);        // 学习已结束，本次学习时间
  delay(180);
  play_duration_seconds(total_seconds);
}

void send_env_query_to_k1() {
  uint8_t packet[3] = {0xAB, CMD_ENV_REPORT, 0x55};
  Serial.write(packet, 3);
}

void handle_k1_cmd(uint8_t rx_cmd) {
  // K1 扩展协议：AA cmd 55，后面可能跟 0D 0A，状态机自动忽略。
  delay(50);

  if (rx_cmd == 0x01) {
    play_good_variant();
  }
  else if (rx_cmd == 0x02) {
    play_slouch_mild_variant();
  }
  else if (rx_cmd == 0x03) {
    play_shoulder_mild_variant();
  }
  else if (rx_cmd == 0x04) {
    play_slouch_severe_variant();
  }
  else if (rx_cmd == 0x05) {
    play_shoulder_severe_variant();
  }
  else if (rx_cmd == 0x06) {
    play_both_bad_variant();
  }
  else if (rx_cmd == 0x07) {
    play_person_lost_variant();
  }
  else if (rx_cmd == CMD_ENV_FAIL) {
    play_env_fail();
  }
}

// ==================== 3. 使用 UART0 / TX0 RX0 接收 K1 指令 ====================
void UART0_RX(){
  uint8_t rx_state = 0;
  uint8_t rx_cmd = 0;
  uint8_t env_temp = 0;
  uint8_t env_hum = 0;

  while (1) {
    while (Serial.available() > 0){
      uint8_t data = Serial.read();

      // 注意：这里不要 Serial.print 调试信息。
      // Serial 现在就是 K1 通信串口，打印文字会干扰协议。

      if (rx_state == 0) {
        if (data == 0xAA) {
          rx_state = 1;
        }
      }
      else if (rx_state == 1) {
        rx_cmd = data;
        if (rx_cmd == CMD_ENV_REPORT) {
          rx_state = 3;   // 环境包：AA 20 temp hum 55
        } else {
          rx_state = 2;   // 普通包：AA cmd 55
        }
      }
      else if (rx_state == 2) {
        if (data == 0x55) {
          // 环境读取失败不受坐姿检测开关影响。
          if (rx_cmd == CMD_ENV_FAIL) {
            handle_k1_cmd(rx_cmd);
          }
          // 坐姿播报受开关控制。
          else if (posture_detect_enable) {
            handle_k1_cmd(rx_cmd);
          }
        }
        rx_state = 0;
      }
      else if (rx_state == 3) {
        env_temp = data;
        rx_state = 4;
      }
      else if (rx_state == 4) {
        env_hum = data;
        rx_state = 5;
      }
      else if (rx_state == 5) {
        if (data == 0x55) {
          // 温湿度播报不受坐姿检测开关影响。
          play_env_report(env_temp, env_hum);
        }
        rx_state = 0;
      }
    }
    delay(2);
  }

  vTaskDelete(NULL);
}

// ==================== 4. 离线语音唤醒/命令词回调区 ====================
void ASR_CODE(){
  set_state_enter_wakeup(10000);

  switch (snid) {
    case 1:
      posture_detect_enable = true;
      break;

    case 2:
      posture_detect_enable = false;
      break;

    case 3:
      if (posture_detect_enable) play_audio(10523);
      else play_audio(10524);
      break;

    case 4:
      // 语音命令：播报环境状态
      // setup 里的 ASRTO 已经会说“正在为您查询环境数据”，这里仅向 K1 发请求。
      send_env_query_to_k1();
      break;

    case 5:
      // 语音命令：当前温湿度
      send_env_query_to_k1();
      break;

    case 6:
      // 语音命令：开始学习
      start_study_timer();
      break;

    case 7:
      // 语音命令：学多久了
      report_study_time();
      break;

    case 8:
      // 语音命令：停止学习
      stop_study_timer();
      break;
  }
}

void app(){
  while (1) {
    delay(100);
  }

  vTaskDelete(NULL);
}

// ==================== 5. 硬件初始化 ====================
void hardware_init(){
  // 音量 0~10。比赛演示可适当调大。
  vol_set(4);

  // 使用 UART0，也就是 TX0/RX0。
  // 波特率必须和 K1 main.cpp 中的 B9600 一致。
  Serial.begin(9600);

  xTaskCreate(UART0_RX, "UART0_RX", 512, NULL, 4, NULL);
  xTaskCreate(app, "app", 128, NULL, 4, NULL);

  vTaskDelete(NULL);
}

void setup()
{
  //{ID:0,keyword:"唤醒词",ASR:"小助手",ASRTO:"我在呢"}
  //{ID:1,keyword:"命令词",ASR:"开始检测",ASRTO:"已打开坐姿检测"}
  //{ID:2,keyword:"命令词",ASR:"关闭检测",ASRTO:"已关闭坐姿检测"}
  //{ID:3,keyword:"命令词",ASR:"检测状态",ASRTO:"正在为您查询"}
  //{ID:4,keyword:"命令词",ASR:"播报环境状态",ASRTO:"正在获取环境状态"}
  //{ID:5,keyword:"命令词",ASR:"当前温湿度",ASRTO:"正在获取环境状态"}
  //{ID:6,keyword:"命令词",ASR:"开始学习",ASRTO:""}
  //{ID:7,keyword:"命令词",ASR:"学多久了",ASRTO:""}
  //{ID:8,keyword:"命令词",ASR:"停止学习",ASRTO:""}

  setPinFun(4, FIRST_FUNCTION);
  pinMode(4, output);
  digitalWrite(4, 0);
}

